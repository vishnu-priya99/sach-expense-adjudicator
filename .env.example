# Environment variables configuration example.
# Copy this file to .env and fill in the values before running the application.

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Platform Configuration
GCP_PROJECT_ID=your_gcp_project_id_here
BQ_DATASET=your_bigquery_dataset_name_here
GCS_BUCKET=your_cloud_storage_bucket_name_here

# Model Configurations
MODEL_NAME=gemini-3.5-flash
MODEL_NAME_TTS=gemini-3.1-flash-tts-preview

# Mock Provider MCP Endpoints (GSTIN-verified endpoints)
HOTEL_MCP_ENDPOINT=http://localhost:8001
RESTAURANT_MCP_ENDPOINT=http://localhost:8002
CAB_MCP_ENDPOINT=http://localhost:8003

